{
    "name": "imedia-menu",
    "version": "1.5.0",
    "private": true,
    "scripts": {
        "build": "npm run build:settings && npm run build:panel && npm run build:block && npm run build:divi",
        "build:block": "npm --prefix assets/blocks/navigation-block run build",
        "build:settings": "npm --prefix assets/admin/settings-page run build",
        "build:panel": "npm --prefix assets/admin/panel-builder run build",
        "build:divi": "npm --prefix src/Integrations/Divi/location/visual-builder run build",
        "start:settings": "npm --prefix assets/admin/settings-page run start",
        "start:panel": "npm --prefix assets/admin/panel-builder run start",
        "test:js": "jest",
        "test:e2e": "playwright test"
    },
    "devDependencies": {
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "@playwright/test": "^1.40.0"
    },
    "jest": {
        "testEnvironment": "jsdom",
        "testMatch": [
            "<rootDir>/tests/js/**/*.test.js"
        ],
        "transform": {}
    }
}
