{
    "name": "inventive-media/imedia-menu",
    "description": "Premium-grade WordPress navigation and mega menu plugin. Fully free and open-source.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Inventive Media",
            "homepage": "https://inventivemedia.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "composer/installers": "^2.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "wp-phpunit/wp-phpunit": "^6.0",
        "yoast/phpunit-polyfills": "^2.0",
        "phpstan/phpstan": "^1.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "IMedia\\Menu\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IMedia\\Menu\\Tests\\": "tests/php/"
        }
    },
    "scripts": {
        "phpcs": "vendor/bin/phpcs --standard=phpcs.xml.dist",
        "phpcbf": "vendor/bin/phpcbf --standard=phpcs.xml.dist",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=2G",
        "phpunit": "vendor/bin/phpunit -c phpunit-unit.xml.dist",
        "build": "npm run build",
        "test": ["@phpcs", "@phpstan", "@phpunit"]
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
